rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'client';
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isTrainer() {
      return isAuthenticated() && (getUserRole() == 'trainer' || getUserRole() == 'admin');
    }

    function isClient() {
      return isAuthenticated() && getUserRole() == 'client';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    match /clients/{clientId} {
      allow read, write: if isTrainer() || (isClient() && resource.data.uid == request.auth.uid);
      allow create: if isTrainer() || (isClient() && request.resource.data.uid == request.auth.uid && request.resource.id == request.auth.uid);
    }

    match /foodItems/{foodId} {
      allow read: if isAuthenticated();
      allow write: if isTrainer();
    }

    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow write: if isTrainer();
    }

    match /supplementCatalog/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isTrainer();
    }

    match /mealPlanVersions/{versionId} {
      allow read: if isAuthenticated();
      allow write: if isTrainer();
    }

    match /workoutPlanVersions/{versionId} {
      allow read: if isAuthenticated();
      allow write: if isTrainer();
    }

    match /regimenVersions/{versionId} {
      allow read: if isAuthenticated();
      allow write: if isTrainer();
    }

    match /logsMeals/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /logsWorkouts/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /logsRegimen/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /logsWater/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /stepsEntries/{entryId} {
      allow read, write: if isAuthenticated();
    }

    match /workoutSessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    match /checkinTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sessionSurveyTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /workoutSessionSurveys/{surveyId} {
      allow read, write: if isAuthenticated();
    }

    match /checkins/{checkinId} {
      allow read, write: if isAuthenticated();
    }

    match /feedback/{feedbackId} {
      allow read, write: if isAuthenticated();
    }

    match /messageThreads/{threadId} {
      allow read, write: if isAuthenticated();
    }

    match /messages/{threadId}/items/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /forums/{forumId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
      match /threads/{threadId} {
        allow read, write: if isAuthenticated();
        match /posts/{postId} {
          allow read, write: if isAuthenticated();
        }
      }
    }

    match /forumMembers/{memberId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    match /fcmTokens/{uid}/tokens/{tokenId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    match /allowedEmails/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /userPreferences/{uid} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    match /productivityEntries/{entryId} {
      allow read, write: if isAuthenticated();
    }

    match /calendarEvents/{eventId} {
      allow read, write: if isAuthenticated();
    }

    match /communityChallenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /challengeParticipants/{participantId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /habits/{habitId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTrainer();
    }

    match /clientNotes/{noteId} {
      allow read, write: if isTrainer();
    }

    match /weeklyRecaps/{recapId} {
      allow read, write: if isTrainer();
    }

    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /clientGoals/{goalId} {
      allow read, write: if isAuthenticated();
    }

    match /progressPhotos/{photoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /progressMeasurements/{measurementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    match /clientAchievements/{achievementId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }
  }
}
